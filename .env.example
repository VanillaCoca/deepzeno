# Supabase Auth / SSR
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Invite gate. Comma-separated shared invite codes required before login.
# Leave empty to disable the gate (dev). INVITE_SECRET signs the invite cookie;
# it falls back to SUPABASE_SERVICE_ROLE_KEY when unset.
INVITE_CODES=
INVITE_SECRET=

# Optional direct Postgres (leave empty to use Supabase REST/API mode)
POSTGRES_URL=

# Primary model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# DeepSeek OpenAI-compatible endpoint
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter (OpenAI-compatible) — temporary flagship stand-in until Bedrock
# access is granted. Set OPENROUTER_API_KEY to light up Opus 4.8 + GPT-5.5;
# remove it to switch back to Bedrock. Confirm slugs at https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_OPUS_MODEL=anthropic/claude-opus-4.8
OPENROUTER_GPT_MODEL=openai/gpt-5.5

# DashScope OpenAI-compatible endpoint
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
DASHSCOPE_MODEL=

# Existing template services
REDIS_URL=
BLOB_READ_WRITE_TOKEN=
AI_GATEWAY_API_KEY=
